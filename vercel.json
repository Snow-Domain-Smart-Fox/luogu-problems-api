{
  "version": 2,
  "routes": [
    {
      "src": "/api/all",
      "dest": "/api/all.js"
    },
    {
      "src": "/api/cron",
      "dest": "/api/cron.js"
    },
    {
      "src": "/api/crawl-page",
      "dest": "/api/crawl-page.js"
    },
    {
      "src": "/api/crawl-status",
      "dest": "/api/crawl-status.js"
    },
    {
      "src": "/api/health",
      "dest": "/api/health.js"
    },
    {
      "src": "/api",
      "dest": "/api/index.js"
    },
    {
      "src": "/",
      "dest": "/api/index.js"
    }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 0 1 * *"
    },
    {
      "path": "/api/crawl-page?auto=true",
      "schedule": "10 0 1 * *"
    }
  ]
}
